{
  "schema_version": "literature_provider_config@1",
  "profile": "default",
  "providers": {
    "openalex": {"enabled": true},
    "semantic_scholar": {"enabled": true},
    "arxiv": {"enabled": true},
    "crossref": {"enabled": true}
  },
  "request": {
    "timeout_seconds": 20,
    "max_retries": 3,
    "backoff_seconds": 1.0,
    "max_response_bytes": 10485760
  },
  "limits": {
    "per_page": 10,
    "max_pages_per_call": 1,
    "max_records_per_query": 12
  },
  "cache": {
    "enabled": true,
    "ttl_seconds": 86400
  },
  "paths": {
    "cache_subdir": "cache/g02/providers",
    "corpus_subdir": "corpus/g02",
    "raw_artifact_subdir": "g02/provider-raw"
  },
  "rate_limits": {
    "openalex_min_interval_seconds": 0.1,
    "semantic_scholar_min_interval_seconds": 1.0,
    "arxiv_min_interval_seconds": 3.0,
    "crossref_min_interval_seconds": 0.2
  },
  "web": {
    "enabled": true,
    "mode": "tavily",
    "providers": {
      "tavily": {"enabled": true},
      "searxng": {
        "enabled": false,
        "endpoint": null,
        "allow_http_loopback_dev": false,
        "categories": ["general", "news"]
      }
    },
    "request": {
      "timeout_seconds": 15,
      "max_retries": 2,
      "backoff_seconds": 1.0,
      "max_response_bytes": 2097152
    },
    "limits": {
      "max_queries_per_task": 12,
      "max_tavily_queries_per_task": 6,
      "max_searxng_queries_per_task": 10,
      "max_results_per_query": 12,
      "auto_searxng_results_per_route": 5,
      "max_extractions_per_task": 6,
      "max_extracted_characters": 60000
    },
    "cache": {"enabled": true, "ttl_seconds": 21600},
    "paths": {
      "cache_subdir": "cache/g02/web",
      "raw_artifact_subdir": "g02/web-provider-raw",
      "extract_artifact_subdir": "g02/web-case-content"
    },
    "rate_limits": {
      "tavily_min_interval_seconds": 1.0,
      "searxng_min_interval_seconds": 1.0
    },
    "source_tiers": {
      "tier_1_domains": [
        "sec.gov", "cftc.gov", "fca.org.uk", "esma.europa.eu", "knf.gov.pl",
        "amf-france.org", "justice.gov", "europa.eu"
      ],
      "tier_2_domains": [
        "reuters.com", "ft.com", "bloomberg.com", "wsj.com", "risk.net"
      ],
      "tier_3_domains": ["example.com"],
      "excluded_domains": []
    }
  },
  "retrieval": {
    "enabled": true,
    "providers": {
      "record": {"enabled": true},
      "unpaywall": {"enabled": true},
      "core": {"enabled": false},
      "doab": {"enabled": true},
      "oapen": {"enabled": true}
    },
    "request": {
      "timeout_seconds": 30,
      "max_retries": 2,
      "backoff_seconds": 1.0,
      "max_metadata_response_bytes": 4194304,
      "max_document_bytes": 52428800,
      "max_redirects": 5
    },
    "limits": {"max_documents_per_task": 20},
    "rate_limits": {
      "record_min_interval_seconds": 0.0,
      "unpaywall_min_interval_seconds": 0.1,
      "core_min_interval_seconds": 1.0,
      "doab_min_interval_seconds": 1.0,
      "oapen_min_interval_seconds": 1.0
    },
    "paths": {
      "temp_subdir": "corpus/g02/temp",
      "accepted_subdir": "corpus/g02/runs",
      "market_case_subdir": "corpus/g02/market-cases"
    }
  }
}
