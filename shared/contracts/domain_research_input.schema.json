{
  "title": "Scoped input for one G02-A02 Domain run",
  "x-version": "1.0",
  "x-major": 1,
  "type": "object",
  "required": [
    "schema_version",
    "task_id",
    "research_plan_ref",
    "research_plan_artifact_version",
    "topic",
    "provider_capabilities",
    "output_language"
  ],
  "properties": {
    "schema_version": {"type": "string", "enum": ["domain_research_input@1"]},
    "task_id": {"type": "string"},
    "research_plan_ref": {"type": "string"},
    "research_plan_artifact_version": {"type": "string"},
    "topic": {"type": "object"},
    "provider_capabilities": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["provider", "enabled", "ready", "authentication"],
        "properties": {
          "provider": {"type": "string", "enum": ["openalex", "semantic_scholar", "arxiv"]},
          "enabled": {"type": "boolean"},
          "ready": {"type": "boolean"},
          "authentication": {
            "type": "string",
            "enum": ["none", "optional_key", "required_key_missing", "configured_key"]
          }
        }
      }
    },
    "output_language": {"type": "string"}
  }
}
