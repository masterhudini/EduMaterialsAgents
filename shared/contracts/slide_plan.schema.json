{
  "title": "SlidePlan — the new-deck skeleton: existing slides (with a change status) and proposed new slides interleaved in order (g03-a02).",
  "x-version": "1.0",
  "x-major": 1,
  "type": "object",
  "required": [
    "schema_version", "task_id", "output_language", "slots"
  ],
  "properties": {
    "schema_version": {"type": "string", "enum": ["slide_plan@1"]},
    "task_id": {"type": "string"},
    "output_language": {"type": "string"},
    "deck_summary": {"type": "string"},
    "target_duration_minutes": {"type": "integer"},
    "slots": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["slot_id", "position", "kind", "status"],
        "properties": {
          "slot_id": {"type": "string"},
          "position": {"type": "integer"},
          "kind": {"type": "string", "enum": ["existing", "new"]},
          "status": {
            "type": "string",
            "enum": ["KEEP", "UPDATE", "REMOVE", "ADD", "MERGE", "SPLIT", "REORDER"]
          },
          "source_slide_ids": {"type": "array", "items": {"type": "string"}},
          "section_id": {"type": "string"},
          "working_title": {"type": "string"},
          "power_title": {"type": "string"},
          "teaching_message": {"type": "string"},
          "original_content": {"type": "string"},
          "web_case_facts": {"type": "array", "items": {"type": "object"}},
          "rationale": {"type": "string"},
          "content_pointers": {
            "type": "object",
            "properties": {
              "keep": {"type": "array", "items": {"type": "string"}},
              "add": {"type": "array", "items": {"type": "string"}},
              "remove": {"type": "array", "items": {"type": "string"}}
            }
          },
          "applied_update_ids": {"type": "array", "items": {"type": "string"}},
          "evidence_basis": {"type": "array", "items": {"type": "string"}},
          "source_refs": {"type": "array", "items": {"type": "string"}},
          "locked": {"type": "boolean"},
          "is_new_information": {"type": "boolean"}
        }
      }
    },
    "deferred_items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["item_id", "reason"],
        "properties": {
          "item_id": {"type": "string"},
          "reason": {"type": "string"},
          "related_claim_ref": {"type": "string"}
        }
      }
    },
    "source_attribution": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source_ref"],
        "properties": {
          "source_ref": {"type": "string"},
          "used_for": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "change_stats": {
      "type": "object",
      "properties": {
        "keep": {"type": "integer"},
        "update": {"type": "integer"},
        "add": {"type": "integer"},
        "remove": {"type": "integer"},
        "merge": {"type": "integer"},
        "split": {"type": "integer"},
        "reorder": {"type": "integer"}
      }
    }
  }
}
