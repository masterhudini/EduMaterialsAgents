      "required": [
        "schema_version", "max_windows_per_source", "max_chars_per_window", "requests"
      ],
      "properties": {
        "schema_version": {"type": "string", "enum": ["a07_deep_dive@1"]},
        "max_windows_per_source": {"type": "integer"},
        "max_chars_per_window": {"type": "integer"},
        "requests": {"type": "array", "items": {"type": "object"}}
      }
    },
    "intake_context": {
