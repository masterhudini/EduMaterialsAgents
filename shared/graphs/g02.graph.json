    {"name": "g02-a08-claim-verification", "kind": "agent", "complexity_class": "evidence_high_impact", "review_profile": "claim_assessment", "output_contract": "claim_assessment@1", "produces": ["ClaimAssessmentState"]},
    {"name": "g02-a09-synthesizer", "kind": "agent", "complexity_class": "synthesis_decision", "review_profile": "research_synthesis", "output_contract": "research_state@1", "produces": ["ResearchState", "EvidenceMap", "UserResearchValidationPacket", "SolutionInputCandidate"]},
    {"name": "user-research-gate", "kind": "user-gate", "required_decisions": [{"id": "approve_required_updates", "type": "approve"}, {"id": "approve_optional_improvements", "type": "approve"}, {"id": "unresolved_claim_handling", "type": "choice"}]}
