    {"name": "g02-a02-domain", "kind": "agent", "complexity_class": "research_search", "input_contract": "domain_research_input@1", "output_contract": "domain_candidate_sources@1", "review_profile": "domain_candidates", "produces": ["domain_candidate_sources@1"]},
    {"name": "g02-a03-canonical-sources", "kind": "agent", "complexity_class": "research_search", "input_contract": "canonical_research_input@1", "review_profile": "canonical_sources", "output_contract": "candidate_sources@1", "produces": ["candidate_sources@1"]},
    {"name": "g02-a04-recent-developments", "kind": "agent", "complexity_class": "research_search", "input_contract": "recent_research_input@1", "review_profile": "recent_developments", "output_contract": "candidate_sources@1", "produces": ["candidate_sources@1"]},
    {"name": "g02-a11-market-cases", "kind": "agent", "complexity_class": "research_search", "input_contract": "market_case_research_input@1", "review_profile": "market_cases", "output_contract": "candidate_sources@1", "produces": ["candidate_sources@1"]},
    {"name": "g02-a05-candidate-source-index", "kind": "agent", "complexity_class": "synthesis_decision", "input_contract": "candidate_index_input@1", "review_profile": "candidate_index", "output_contract": "candidate_source_index@1", "produces": ["candidate_source_index@1", "candidate_source_review.md"]},
