{
  "graph_id": "research",
  "description": "Research Graph. Verifies approved claims and finds current literature for a lecture refresh, then freezes a UserApprovedResearchBundle. SINGLE SOURCE OF TRUTH for the node sequence — research_flow.py and the orchestrator prompt must agree with this manifest. Authoritative design: docs/02_Architektura_agentow_i_skilli.md. Reviewers are runs of ONE physical agent (research-output-reviewer) with a per-node review_profile; the two user gates are orchestrator steps, not agents. The standalone deterministic harness may use injectable no-op executors for wiring tests until the runtime adapter is implemented.",
  "orchestrator": "orchestrate-research",
  "reviewer": "research-output-reviewer",
  "retry_matrix": {
    "deterministic_technical": {"low": 0, "medium": 1, "high": 2, "critical": 3},
    "research_planning": {"low": 0, "medium": 2, "high": 3, "critical": 3},
    "research_search": {"low": 0, "medium": 2, "high": 3, "critical": 3},
    "evidence_high_impact": {"low": 1, "medium": 2, "high": 3, "critical": 3},
    "synthesis_decision": {"low": 0, "medium": 1, "high": 2, "critical": 3}
  },
  "default_escalation": "user-research-gate",
  "reviewer_complexity_class": "cross_artifact_reconciliation",
  "model_bindings": {
    "research_planning": {"claude": "opus"},
    "research_search": {"claude": "sonnet"},
    "synthesis_decision": {"claude": "opus"},
    "deterministic_technical": {"claude": "sonnet"},
    "evidence_high_impact": {"claude": "opus"},
    "cross_artifact_reconciliation": {"claude": "opus"}
  },
  "entry_node": "research-planner",
  "input_contract": "research_graph_input@1",
  "exit_artifact": "user_approved_research_bundle@1",
  "nodes": [
    {"name": "research-planner", "kind": "agent", "complexity_class": "research_planning", "review_profile": "research_plan", "output_contract": "research_plan@1", "produces": ["ResearchPlan"]},
    {"name": "research-domain", "kind": "agent", "complexity_class": "research_search", "review_profile": "domain_candidates", "output_contract": "candidate_sources@1", "produces": ["DomainCandidateSources"]},
    {"name": "research-canonical-sources", "kind": "agent", "complexity_class": "research_search", "review_profile": "canonical_sources", "output_contract": "candidate_sources@1", "produces": ["CanonicalCandidateSources"]},
    {"name": "research-recent-developments", "kind": "agent", "complexity_class": "research_search", "review_profile": "recent_developments", "output_contract": "candidate_sources@1", "produces": ["RecentCandidateSources"]},
    {"name": "research-candidate-source-index", "kind": "agent", "complexity_class": "synthesis_decision", "review_profile": "candidate_index", "output_contract": "candidate_source_index@1", "produces": ["CandidateSourceIndex"]},
    {"name": "user-source-selection-gate", "kind": "user-gate", "required_decisions": [{"id": "source_actions", "type": "per_source_action", "actions": ["DOWNLOAD", "LIBRARY", "CITATION", "RESERVE", "EXCLUDE", "SEARCH_MORE"]}]},
    {"name": "research-paper-retrieval", "kind": "agent", "complexity_class": "deterministic_technical", "review_profile": "retrieved_corpus", "output_contract": "retrieved_corpus@1", "produces": ["RetrievedCorpus"]},
    {"name": "research-paper-review", "kind": "agent", "complexity_class": "evidence_high_impact", "review_profile": "paper_evidence", "output_contract": "paper_review@1", "produces": ["PaperReview", "PaperEvidenceCards"]},
    {"name": "research-claim-verification", "kind": "agent", "complexity_class": "evidence_high_impact", "review_profile": "claim_assessment", "output_contract": "claim_assessment@1", "produces": ["ClaimAssessmentState"]},
    {"name": "research-synthesizer", "kind": "agent", "complexity_class": "synthesis_decision", "review_profile": "research_synthesis", "output_contract": "research_state@1", "produces": ["ResearchState", "EvidenceMap", "UserResearchValidationPacket", "SolutionInputCandidate"]},
    {"name": "user-research-gate", "kind": "user-gate", "required_decisions": [{"id": "approve_required_updates", "type": "approve"}, {"id": "approve_optional_improvements", "type": "approve"}, {"id": "unresolved_claim_handling", "type": "choice"}]}
  ],
  "sequence": [
    "research-planner",
    "research-domain",
    "research-canonical-sources",
    "research-recent-developments",
    "research-candidate-source-index",
    "user-source-selection-gate",
    "research-paper-retrieval",
    "research-paper-review",
    "research-claim-verification",
    "research-synthesizer",
    "user-research-gate"
  ]
}
