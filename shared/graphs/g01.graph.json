  "reviewer_complexity_class": "cross_artifact_reconciliation",
  "retry_matrix": {
    "deterministic_technical": {"low": 0, "medium": 1, "high": 2, "critical": 3},
    "semantic_high_ambiguity": {"low": 1, "medium": 2, "high": 3, "critical": 3},
    "synthesis_decision": {"low": 0, "medium": 1, "high": 2, "critical": 3},
    "cross_artifact_reconciliation": {"low": 0, "medium": 2, "high": 3, "critical": 3}
  },
  "default_escalation": "user-intake-gate",
  "model_bindings": {
    "deterministic_technical": {"claude": "sonnet"},
    "semantic_high_ambiguity": {"claude": "opus"},
    "synthesis_decision": {"claude": "opus"},
    "cross_artifact_reconciliation": {"claude": "opus"}
  },
  "entry_node": "g01-a01-pdf-intake",
  "input_contract": "intake_graph_input@1",
  "exit_artifact": "research_graph_input@1",
  "nodes": [
    {"name": "g01-a01-pdf-intake", "kind": "agent", "complexity_class": "deterministic_technical", "review_profile": "slide_views", "output_contract": "slide_views@1", "produces": ["SlideViews"]},
    {"name": "g01-a02-understanding", "kind": "agent", "complexity_class": "semantic_high_ambiguity", "review_profile": "understanding", "output_contract": "intake_understanding@1", "produces": ["IntakeUnderstanding"]},
    {"name": "g01-a03-intake-synthesizer", "kind": "agent", "complexity_class": "synthesis_decision", "review_profile": "intake_synthesis", "output_contract": "research_graph_input@1", "produces": ["ResearchGraphInput"]},
    {"name": "user-intake-gate", "kind": "user-gate", "required_decisions": [{"id": "confirm_audience", "type": "confirm"}, {"id": "confirm_domains", "type": "confirm"}, {"id": "approve_research_scope", "type": "approve"}, {"id": "mark_locked_sections", "type": "choice"}]}
  ],
  "sequence": [
    "g01-a01-pdf-intake",
    "g01-a02-understanding",
    "g01-a03-intake-synthesizer",
    "user-intake-gate"
  ]
