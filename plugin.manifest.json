{
  "name": "edu-materials-agents",
  "version": "0.11.0",
  "description": "Agent-stack plugin for improving educational / lecture materials through agent graphs (intake -> research -> solution).",
  "author": {
    "name": "khudasze"
  },
  "license": "MIT",
  "keywords": [
    "agents",
    "education",
    "research-graph",
    "claude-code",
    "codex"
  ],
  "category": {
    "claude": "development",
    "codex": "Developer Tools"
  },
  "marketplace": {
    "name": "edu-materials",
    "displayName": "Edu Materials",
    "description": "Local marketplace for the edu-materials-agents plugin."
  },
  "interface": {
    "displayName": "Edu Materials Agents",
    "shortDescription": "Improve lecture materials through intake, research and solution agent graphs.",
    "longDescription": "Runs agent graphs for educational material improvement. The active G02 path plans with A01, runs deterministic Scout discovery, reads bounded Scout windows in A07, synthesizes with A09, pauses at the Human Research Gate and finalizes a compact Graph03 bundle only after user approval.",
    "developerName": "khudasze",
    "capabilities": [
      "Interactive",
      "Read",
      "Write"
    ],
    "defaultPrompt": [
      "Run the research graph for this lecture input."
    ],
    "brandColor": "#2F6F73"
  },
  "components": {
    "skills": [
      "skills/orchestrate-workflow",
      "skills/g01-orchestrate-intake",
      "skills/g03-orchestrate-solution",
      "skills/g02-a01-plan-research-scope",
      "skills/g02-a07-review-source",
      "skills/g02-a09-synthesize",
      "skills/g02-assess-source-coverage",
      "skills/g02-orchestrate-research",
      "skills/g03-a02-plan-slide-deck",
      "skills/g03-a03-design-slides",
      "skills/g03-a04-prompt-notebooklm",
      "skills/g03-a04-prompt-gamma",
      "skills/g03-a04-prompt-gpt-pro"
    ],
    "agents": [
      "agents/g01-a01-pdf-intake.md",
      "agents/g01-a02-understanding.md",
      "agents/g01-a03-intake-synthesizer.md",
      "agents/g01-a04-lecture-baseline.md",
      "agents/g01-a10-output-reviewer.md",
      "agents/g02-a01-planner.md",
      "agents/g02-a11-market-cases.md",
      "agents/g02-a07-paper-review.md",
      "agents/g02-a09-synthesizer.md",
      "agents/g02-a08-claim-verification.md",
      "agents/g03-a01-solution-architect.md",
      "agents/g03-a02-slide-architect.md",
      "agents/g03-a03-slide-designer.md",
      "agents/g03-a04-prompt-builder.md",
      "agents/g03-a10-output-reviewer.md"
    ],
    "commands": [
      "commands/research.md"
    ],
    "shared": [
      "shared"
    ]
  },
  "mcpServers": {
    "edu-materials-research": {
      "command": "{python}",
      "entrypoint": "shared/scripts/mcp/research_server.py"
    },
    "edu-materials-intake": {
      "command": "{python}",
      "entrypoint": "shared/scripts/mcp/intake_server.py"
    },
    "edu-materials-solution": {
      "command": "{python}",
      "entrypoint": "shared/scripts/mcp/solution_server.py"
    }
  },
  "hosts": {
    "claude": {
      "includeCommands": true,
      "includeAgents": true,
      "manifestDir": ".claude-plugin"
    },
    "codex": {
      "includeCommands": false,
      "includeAgents": true,
      "manifestDir": ".codex-plugin"
    }
  }
}
