    "openalex": {"enabled": false},
    "semantic_scholar": {"enabled": true},
    "arxiv": {"enabled": false}
  },
  "request": {"timeout_seconds": 5, "max_retries": 0, "backoff_seconds": 0, "max_response_bytes": 1048576},
  "limits": {"per_page": 10, "max_pages_per_call": 1, "max_records_per_query": 12},
