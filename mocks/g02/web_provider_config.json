    "request": {"timeout_seconds": 5, "max_retries": 0, "backoff_seconds": 0, "max_response_bytes": 1048576},
    "limits": {"max_queries_per_task": 12, "max_tavily_queries_per_task": 6, "max_searxng_queries_per_task": 10, "max_results_per_query": 6, "auto_searxng_results_per_route": 3, "max_extractions_per_task": 3, "max_extracted_characters": 20000},
    "cache": {"enabled": true, "ttl_seconds": 3600},
    "paths": {"cache_subdir": "cache/g02/web", "raw_artifact_subdir": "g02/web-provider-raw", "extract_artifact_subdir": "g02/web-case-content"},
